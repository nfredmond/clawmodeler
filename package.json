{
  "name": "clawmodeler",
  "version": "1.0.0",
  "description": "Local-first transportation sketch-planning for small and rural agencies.",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "engine": "python3 -m clawmodeler_engine",
    "engine:test": "python3 -m unittest discover -s tests -p '*test*.py'",
    "engine:check": "bash scripts/check-packaging.sh",
    "desktop:acceptance": "bash scripts/check-desktop-acceptance.sh",
    "release:assets": "node scripts/check-release-assets.mjs",
    "release:assets:test": "node scripts/check-release-assets.mjs --self-test",
    "release:dry-run": "node scripts/check-release-dry-run.mjs",
    "release:dry-run:test": "node scripts/check-release-dry-run.mjs --self-test",
    "release:latest-policy:test": "node scripts/release-latest-policy.mjs --self-test",
    "release:version-check": "node scripts/check-version-consistency.mjs",
    "release:sidecar-smoke": "node scripts/check-release-sidecar.mjs",
    "release:macos-dmg-smoke": "node scripts/check-macos-dmg-smoke.mjs",
    "release:macos-dmg-smoke:test": "node scripts/check-macos-dmg-smoke.mjs --self-test",
    "release:first-user-smoke": "node scripts/check-first-user-smoke.mjs",
    "release:workflow:test": "node scripts/check-release-workflows.mjs",
    "ui:dev": "pnpm --dir desktop dev",
    "ui:build": "pnpm --dir desktop build",
    "ui:typecheck": "pnpm --dir desktop typecheck",
    "ui:test": "pnpm --dir desktop test",
    "tauri:dev": "pnpm --dir desktop tauri:dev",
    "tauri:build": "pnpm --dir desktop tauri:build",
    "sidecar:build": "pnpm --dir desktop sidecar:build"
  }
}
